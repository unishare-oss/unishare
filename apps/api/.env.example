# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/unishare

# BetterAuth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3001

# Frontend
FRONTEND_URL=http://localhost:3000

# Cookie domain for cross-subdomain auth
COOKIE_DOMAIN=

# Microsoft Entra ID (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# S3-compatible Storage (Cloudflare R2, MinIO, AWS S3, etc.)
S3_ENDPOINT=https:// <account >.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=unishare
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=https://your-public-bucket-url.com

# Academic calendar (month number 1-12 when the academic year starts, default: 8 = August)
ACADEMIC_START_MONTH=8

# Server
PORT=3001
