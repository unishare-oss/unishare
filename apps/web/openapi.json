  "info": {
    "title": "Unishare API",
    "description": "API for the Unishare platform",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": { "bearer": { "scheme": "bearer", "bearerFormat": "JWT", "type": "http" } },
    "schemas": {
      "PresignedUploadDto": {
        "type": "object",
        "properties": {
          "mimeType": {
            "type": "string",
            "maxLength": 255,
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9!#$&\\-^_]*\\/[a-zA-Z0-9][a-zA-Z0-9!#$&\\-^_.+]*$"
          },
          "uploadType": { "type": "string", "enum": ["document", "image"] },
          "purpose": { "type": "string", "enum": ["profile-picture", "post-attachment"] }
        },
        "required": ["mimeType", "uploadType", "purpose"]
      },
      "PresignedUploadEntity": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "key": { "type": "string" },
          "publicUrl": { "type": "string" }
        },
        "required": ["url", "key", "publicUrl"]
      },
      "CreateCourseDto": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "minLength": 2, "maxLength": 20 },
          "name": { "type": "string", "minLength": 2, "maxLength": 100 },
          "departmentId": { "type": "string" }
        },
        "required": ["code", "name", "departmentId"]
      },
      "CourseDeptEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "code": { "type": "string" }
        },
        "required": ["id", "name", "code"]
      },
      "CourseEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "departmentId": { "type": "string" },
          "department": { "$ref": "#/components/schemas/CourseDeptEntity" }
        },
        "required": ["id", "code", "name", "departmentId", "department"]
      },
      "PaginatedCourseEntity": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CourseEntity" } },
          "total": { "type": "number" },
          "page": { "type": "number" },
          "limit": { "type": "number" },
          "totalPages": { "type": "number" }
        },
        "required": ["items", "total", "page", "limit", "totalPages"]
      },
      "UpdateCourseDto": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "minLength": 2, "maxLength": 20 },
          "name": { "type": "string", "minLength": 2, "maxLength": 100 },
          "departmentId": { "type": "string" }
        }
      },
      "DepartmentEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "code": { "type": "string" }
        },
        "required": ["id", "name", "code"]
      },
      "UserProfileEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "emailVerified": { "type": "boolean" },
          "image": { "type": "string", "nullable": true },
          "bio": { "type": "string", "nullable": true },
          "role": { "type": "string", "enum": ["STUDENT", "MODERATOR", "ADMIN"] },
          "departmentId": { "type": "string", "nullable": true },
          "department": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/DepartmentEntity" }]
          },
          "enrollmentYear": { "type": "number", "nullable": true },
          "yearLevel": { "type": "number", "nullable": true },
          "shouldShowUpdateMajorPopup": { "type": "boolean" },
