  "info": {
    "title": "Unishare API",
    "description": "API for the Unishare platform",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": { "bearer": { "scheme": "bearer", "bearerFormat": "JWT", "type": "http" } },
    "schemas": {
      "PresignedUploadDto": {
        "type": "object",
        "properties": {
          "purpose": { "type": "string", "enum": ["profile-picture", "post-attachment"] },
          "mimeType": {
            "type": "string",
            "maxLength": 255,
            "pattern": "/^[a-zA-Z0-9][a-zA-Z0-9!#$&\\-^_]*\\/[a-zA-Z0-9][a-zA-Z0-9!#$&\\-^_.+]*$/"
          },
          "uploadType": { "type": "object" }
        },
        "required": ["purpose", "mimeType", "uploadType"]
      },
      "PresignedUploadEntity": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "key": { "type": "string" },
          "publicUrl": { "type": "string" }
        },
        "required": ["url", "key", "publicUrl"]
      },
      "CreateCourseDto": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "minLength": 2, "maxLength": 20 },
          "name": { "type": "string", "minLength": 2, "maxLength": 100 },
          "departmentId": { "type": "string" }
        },
        "required": ["code", "name", "departmentId"]
      },
      "UpdateCourseDto": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "minLength": 2, "maxLength": 20 },
          "name": { "type": "string", "minLength": 2, "maxLength": 100 },
          "departmentId": { "type": "string" }
        }
      },
      "DepartmentEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "code": { "type": "string" }
        },
        "required": ["id", "name", "code"]
      },
      "UserProfileEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "emailVerified": { "type": "boolean" },
          "image": { "type": "string", "nullable": true },
          "role": { "type": "string", "enum": ["STUDENT", "MODERATOR", "ADMIN"] },
          "departmentId": { "type": "string", "nullable": true },
          "department": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/DepartmentEntity" }]
          },
          "enrollmentYear": { "type": "number", "nullable": true },
          "yearLevel": { "type": "number", "nullable": true },
          "shouldShowUpdateMajorPopup": { "type": "boolean" }
        },
        "required": ["id", "name", "email", "emailVerified", "role", "shouldShowUpdateMajorPopup"]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 100 },
          "image": { "type": "string", "maxLength": 500, "format": "uri" },
          "enrollmentYear": { "type": "number", "minimum": 1950, "maximum": 2100 }
        }
      },
      "UpdateAcademicProfileDto": {
        "type": "object",
        "properties": {
          "departmentId": { "type": "string", "nullable": true, "maxLength": 50 },
          "enrollmentYear": { "type": "number", "nullable": true, "minimum": 1950, "maximum": 2100 }
        }
      },
      "CreateDepartmentDto": {
        "type": "object",
        "properties": { "name": { "type": "string", "minLength": 2, "maxLength": 100 } },
        "required": ["name"]
      },
      "UpdateDepartmentDto": {
        "type": "object",
        "properties": { "name": { "type": "string", "minLength": 2, "maxLength": 100 } }
      },
      "CreatePostDto": {
        "type": "object",
        "properties": {
          "type": { "type": "object" },
          "courseId": { "type": "string" },
          "title": { "type": "string", "minLength": 3, "maxLength": 200 },
          "description": { "type": "string", "maxLength": 2000 },
          "externalUrl": { "type": "string", "maxLength": 500, "format": "uri" },
          "examYear": { "type": "number", "minimum": 1900, "maximum": 2100 },
          "moduleNumber": { "type": "number", "minimum": 1, "maximum": 20 },
          "year": { "type": "number", "minimum": 1, "maximum": 6 },
          "semester": { "type": "number", "minimum": 1, "maximum": 3 }
        },
        "required": ["type", "courseId"]
      },
      "Object": { "type": "object", "properties": {} },
      "PostAuthorDeptEntity": {
        "type": "object",
        "properties": { "id": { "type": "string" }, "name": { "type": "string" } },
        "required": ["id", "name"]
      },
      "PostAuthorEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "image": { "type": "string", "nullable": true },
          "enrollmentYear": { "type": "number", "nullable": true },
          "department": {
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/PostAuthorDeptEntity" }]
          }
        },
        "required": ["id", "name"]
      },
      "PostCourseDeptEntity": {
        "type": "object",
        "properties": { "id": { "type": "string" }, "name": { "type": "string" } },
        "required": ["id", "name"]
      },
      "PostCourseEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "department": { "$ref": "#/components/schemas/PostCourseDeptEntity" }
        },
        "required": ["id", "code", "name", "department"]
      },
      "PostFileEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "key": { "type": "string" },
          "name": { "type": "string" },
          "size": { "type": "number" },
          "mimeType": { "type": "string" },
          "postId": { "type": "string" },
          "createdAt": { "format": "date-time", "type": "string" }
        },
        "required": ["id", "key", "name", "size", "mimeType", "postId", "createdAt"]
      },
      "PostCountEntity": {
        "type": "object",
        "properties": { "comments": { "type": "number" }, "savedBy": { "type": "number" } },
        "required": ["comments", "savedBy"]
      },
      "PostEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["NOTE", "OLD_QUESTION"] },
          "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
          "title": { "type": "string", "nullable": true },
          "description": { "type": "string", "nullable": true },
          "externalUrl": { "type": "string", "nullable": true },
          "examYear": { "type": "number", "nullable": true },
          "moduleNumber": { "type": "number", "nullable": true },
          "year": { "type": "number", "nullable": true },
          "semester": { "type": "number", "nullable": true },
          "shortCode": { "type": "string" },
          "authorId": { "type": "string" },
          "courseId": { "type": "string" },
          "createdAt": { "format": "date-time", "type": "string" },
          "updatedAt": { "format": "date-time", "type": "string" },
          "deletedAt": { "format": "date-time", "type": "string", "nullable": true },
          "author": { "$ref": "#/components/schemas/PostAuthorEntity" },
          "course": { "$ref": "#/components/schemas/PostCourseEntity" },
          "files": { "type": "array", "items": { "$ref": "#/components/schemas/PostFileEntity" } },
          "_count": { "$ref": "#/components/schemas/PostCountEntity" },
          "savedByCurrentUser": { "type": "boolean" }
        },
        "required": [
          "id",
          "type",
          "status",
          "shortCode",
          "authorId",
          "courseId",
          "createdAt",
          "updatedAt",
          "author",
          "course",
          "files",
          "_count",
          "savedByCurrentUser"
        ]
      },
      "PaginatedPostEntity": {
        "type": "object",
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/PostEntity" } },
          "total": { "type": "number" },
          "page": { "type": "number" },
          "limit": { "type": "number" },
          "totalPages": { "type": "number" }
        },
        "required": ["items", "total", "page", "limit", "totalPages"]
      },
      "PostCommentUserEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "image": { "type": "string", "nullable": true }
        },
        "required": ["id", "name"]
      },
      "PostCommentEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "content": { "type": "string" },
          "createdAt": { "format": "date-time", "type": "string" },
          "deletedAt": { "format": "date-time", "type": "string", "nullable": true },
          "user": { "$ref": "#/components/schemas/PostCommentUserEntity" }
        },
        "required": ["id", "content", "createdAt", "user"]
      },
      "PostDetailEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["NOTE", "OLD_QUESTION"] },
          "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
          "title": { "type": "string", "nullable": true },
          "description": { "type": "string", "nullable": true },
          "externalUrl": { "type": "string", "nullable": true },
          "examYear": { "type": "number", "nullable": true },
          "moduleNumber": { "type": "number", "nullable": true },
          "year": { "type": "number", "nullable": true },
          "semester": { "type": "number", "nullable": true },
          "shortCode": { "type": "string" },
          "authorId": { "type": "string" },
          "courseId": { "type": "string" },
          "createdAt": { "format": "date-time", "type": "string" },
          "updatedAt": { "format": "date-time", "type": "string" },
          "deletedAt": { "format": "date-time", "type": "string", "nullable": true },
          "author": { "$ref": "#/components/schemas/PostAuthorEntity" },
          "course": { "$ref": "#/components/schemas/PostCourseEntity" },
          "files": { "type": "array", "items": { "$ref": "#/components/schemas/PostFileEntity" } },
          "_count": { "$ref": "#/components/schemas/PostCountEntity" },
          "savedByCurrentUser": { "type": "boolean" },
          "comments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PostCommentEntity" }
          }
        },
        "required": [
          "id",
          "type",
          "status",
          "shortCode",
          "authorId",
          "courseId",
          "createdAt",
          "updatedAt",
          "author",
          "course",
          "files",
          "_count",
          "savedByCurrentUser",
          "comments"
        ]
      },
      "UpdatePostStatusDto": {
        "type": "object",
        "properties": { "status": { "type": "object" } },
        "required": ["status"]
      },
      "UpdatePostDto": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 3, "maxLength": 200 },
          "description": { "type": "string", "maxLength": 2000 },
          "externalUrl": { "type": "string", "maxLength": 500, "format": "uri" },
          "examYear": { "type": "number", "minimum": 1900, "maximum": 2100 },
          "moduleNumber": { "type": "number", "minimum": 1, "maximum": 20 },
          "year": { "type": "number", "minimum": 1, "maximum": 6 },
          "semester": { "type": "number", "minimum": 1, "maximum": 3 }
        }
      },
      "DownloadUrlEntity": {
        "type": "object",
        "properties": { "url": { "type": "string" } },
        "required": ["url"]
      },
      "ConfirmFileUploadDto": {
        "type": "object",
        "properties": {
          "key": { "type": "string", "maxLength": 500 },
          "name": { "type": "string", "maxLength": 255 },
          "size": { "type": "number", "minimum": 1 },
          "mimeType": { "type": "string", "maxLength": 255 }
        },
        "required": ["key", "name", "size", "mimeType"]
      }
    }
  }
}
